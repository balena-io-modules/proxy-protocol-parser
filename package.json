{
  "name": "@balena/proxy-protocol-parser",
  "description": "Encoder and Decoder for proxy protocol v1 text and v2 binary formats",
  "license": "Apache-2.0",
  "version": "1.0.2",
  "types": "typings/proxy-protocol-parser.d.ts",
  "repository": {
    "type": "git",
    "url": "git@github.com:balena-io-modules/proxy-protocol-parser.git"
  },
  "scripts": {
    "lint": "balena-lint -e js -e ts index.js lib/",
    "lint-fix": "balena-lint --fix -e js -e ts index.js lib/",
    "test": "nodeunit",
    "posttest": "tsc --noEmit",
    "prepublish": "require-npm4-to-publish"
  },
  "dependencies": {
    "hexy": "^0.3.0",
    "ip-address": "^10.1.0"
  },
  "devDependencies": {
    "@balena/lint": "^6.2.2",
    "@types/node": "^12.20.55",
    "husky": "^1.3.1",
    "lint-staged": "^8.1.5",
    "nodeunit": "^0.11.3",
    "require-npm4-to-publish": "^1.0.0",
    "typescript": "^5.9.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run lint"
    }
  },
  "lint-staged": {
    "*.js": [
      "balena-lint --fix --typescript",
      "git add"
    ]
  }
}
